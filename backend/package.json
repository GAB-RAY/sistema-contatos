{
  "name": "sistema-contatos-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Backend modular do Sistema de Contatos",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "banco:verificar": "node src/configuracoes/verificarBanco.js",
    "admin:criar": "node src/modulos/usuarios/criarAdministradorInicial.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --runInBand"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/testes"
    ],
    "clearMocks": true,
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js"
    ]
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.6.0",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "supertest": "^7.2.2"
  }
}
